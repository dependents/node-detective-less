{
  "name": "@dependents/detective-less",
  "version": "5.0.3",
  "description": "Find the dependencies of a less file",
  "type": "module",
  "exports": {
    ".": "./index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "index.js"
  ],
  "scripts": {
    "lint": "xo",
    "fix": "xo --fix",
    "uvu": "uvu test -i fixtures",
    "test": "npm run lint && npm run uvu",
    "test:ci": "c8 npm run uvu"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dependents/node-detective-less.git"
  },
  "keywords": [
    "detective",
    "less",
    "ast",
    "dependencies"
  ],
  "author": "Joel Kemp <joel@mrjoelkemp.com>",
  "contributors": [
    "Michael Orenstein <michael@whiteshadows.me>"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/dependents/node-detective-less/issues"
  },
  "homepage": "https://github.com/dependents/node-detective-less",
  "engines": {
    "node": ">=20.19.0 || >=22.12.0"
  },
  "dependencies": {
    "gonzales-pe": "^4.3.0",
    "node-source-walk": "github:dependents/node-source-walk#xmr/dev"
  },
  "devDependencies": {
    "c8": "^11.0.0",
    "uvu": "^0.5.6",
    "xo": "^2.0.2"
  }
}
